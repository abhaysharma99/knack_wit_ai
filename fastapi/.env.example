# General settings
PROJECT_NAME=fast-gpt
ENV=development
DEBUG=true
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Logging
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg2://user:pass@postgres:5432/fast_gpt_db

# Gemini API — get your own key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
